<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EasyCut</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <!-- 激活界面 -->
    <div id="activation-screen" class="activation-screen" style="display: flex !important;">
        <div class="activation-container">
            <div class="activation-card">
                <div class="activation-header">
                    <div class="activation-logo">
                        <div class="logo-icon">E</div>
                    </div>
                    <h1 class="activation-title">EasyCut</h1>
                    <p class="activation-subtitle">专业的网络管理工具</p>
                </div>
                
                <div class="activation-form">
                    <div class="input-group">
                        <div class="input-container">
                            <div class="input-icon">🔑</div>
                            <input 
                                type="text" 
                                id="activation-code-input" 
                                class="activation-input" 
                                placeholder="请输入唯一激活码"
                                maxlength="19"
                            >
                        </div>
                    </div>
                    
                    <button id="activate-button" class="activate-button">
                        激活许可证
                    </button>
                    
                    <div id="activation-message" class="activation-message" style="display: none;"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- 主应用界面 -->
    <div id="main-app" class="container" style="display: none !important;">
        <div class="top-actions">
            <span class="share-label">留言</span>
            <button id="btn-settings" class="settings-icon" title="设置">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                </svg>
            </button>
            <button id="btn-share" class="share-icon">
                <img src="assets/icon_share.svg" alt="share" width="20" height="20"/>
            </button>
        </div>
        <!-- 管理员权限提示 -->
        <div id="admin-warning" class="warning-box" style="display: none;">
            ⚠️ 请以管理员身份运行此程序
        </div>

        <!-- 快速切换按钮区域 -->
        <div class="quick-switch-section">
            <h2>模式切换</h2>
            <div class="button-group">
                <button id="btn-stop-link" class="action-button stop-button">
                    <span class="button-text">启用外网</span>
                    <span class="button-desc">恢复WiFi正常连接</span>
                </button>
                <button id="btn-smart-network" class="action-button both-button">
                    <span class="button-text">同时启用</span>
                    <span class="button-desc">同时启用内外网</span>
                </button>
            </div>
        </div>

        <!-- 分隔线 -->
        <div class="divider"></div>

        <!-- 网络接口区域 -->
        <div class="interface-section">
            <div class="section-header">
                <h2>网络接口</h2>
                <button id="btn-refresh" class="refresh-button" title="强制重新加载（Ctrl+Shift+R）">
                    <span class="refresh-label">更新</span>
                    <img src="assets/icon_refresh.png" alt="刷新" class="refresh-icon" width="20" height="20"/>
                </button>
            </div>
            
            <div id="interface-list" class="interface-list">
                <div class="loading">加载中...</div>
            </div>
        </div>

        <!-- 状态栏 -->
        <div id="status-bar" class="status-bar">
            <span id="status-text">就绪</span>
        </div>
    </div>

    <!-- 分享覆盖层（二维码 + 文案） -->
    <div id="share-overlay" class="share-overlay" style="display: none;">
        <div class="share-wrapper">
            <img src="assets/icon_wubai.png" alt="分享二维码" class="share-qr">
            <div class="share-text">公众号500佰<br>欢迎留言 发送EasyCut获取下载链接</div>
        </div>
    </div>

    <!-- 设置面板 -->
    <div id="settings-overlay" class="settings-overlay" style="display: none;">
        <div class="settings-modal" onclick="event.stopPropagation()">
            <!-- 头部 -->
            <div class="settings-header">
                <h2 class="settings-title">设置</h2>
                <button id="btn-close-settings" class="close-button" title="关闭">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>

            <!-- 设置内容 -->
            <div class="settings-content">
                <!-- 通用设置 -->
                <div class="settings-group">
                    <h3 class="settings-group-title">通用设置</h3>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">开机自启动</div>
                            <div class="setting-desc">系统启动时自动运行 EasyCut</div>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" id="setting-auto-start">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">最小化到托盘</div>
                            <div class="setting-desc">点击最小化按钮时隐藏到系统托盘</div>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" id="setting-minimize-to-tray" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">关闭时最小化</div>
                            <div class="setting-desc">点击关闭按钮时最小化而非退出</div>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" id="setting-close-to-minimize" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>

                <!-- 界面设置 -->
                <div class="settings-group">
                    <h3 class="settings-group-title">界面设置</h3>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">主题模式</div>
                        </div>
                        <div class="radio-group" id="setting-theme">
                            <label class="radio-option">
                                <input type="radio" name="theme" value="dark" checked>
                                <span class="radio-label">深色</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="theme" value="light">
                                <span class="radio-label">浅色</span>
                            </label>
                        </div>
                    </div>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">语言</div>
                        </div>
                        <select id="setting-language" class="setting-select">
                            <option value="zh-CN">简体中文</option>
                            <option value="en-US">English</option>
                        </select>
                    </div>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">字体大小</div>
                        </div>
                        <div class="radio-group" id="setting-font-size">
                            <label class="radio-option">
                                <input type="radio" name="fontSize" value="small">
                                <span class="radio-label">小</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="fontSize" value="medium" checked>
                                <span class="radio-label">中</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="fontSize" value="large">
                                <span class="radio-label">大</span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- 网络设置 -->
                <div class="settings-group">
                    <h3 class="settings-group-title">网络设置</h3>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">自动切换模式</div>
                            <div class="setting-desc">根据网络状态自动切换内外网</div>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" id="setting-auto-switch">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">网络检测间隔</div>
                        </div>
                        <select id="setting-check-interval" class="setting-select">
                            <option value="5">5秒</option>
                            <option value="10" selected>10秒</option>
                            <option value="30">30秒</option>
                        </select>
                    </div>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">失败重试次数</div>
                        </div>
                        <select id="setting-retry-count" class="setting-select">
                            <option value="1">1次</option>
                            <option value="3" selected>3次</option>
                            <option value="5">5次</option>
                        </select>
                    </div>
                </div>

                <!-- 通知设置 -->
                <div class="settings-group">
                    <h3 class="settings-group-title">通知设置</h3>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">启用通知</div>
                            <div class="setting-desc">显示系统通知消息</div>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" id="setting-enable-notification" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">声音提醒</div>
                            <div class="setting-desc">操作完成时播放提示音</div>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" id="setting-sound-alert" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">状态变化通知</div>
                            <div class="setting-desc">网络状态变化时发送通知</div>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" id="setting-status-change-notify" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>

                <!-- 高级设置 -->
                <div class="settings-group">
                    <h3 class="settings-group-title">高级设置</h3>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">日志级别</div>
                        </div>
                        <select id="setting-log-level" class="setting-select">
                            <option value="error">错误</option>
                            <option value="warn" selected>警告</option>
                            <option value="debug">调试</option>
                        </select>
                    </div>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">清除缓存</div>
                            <div class="setting-desc">清除应用缓存数据</div>
                        </div>
                        <button id="btn-clear-cache" class="setting-button secondary">清除</button>
                    </div>

                    <div class="setting-item">
                        <div class="setting-info">
                            <div class="setting-name">重置设置</div>
                            <div class="setting-desc">恢复所有设置为默认值</div>
                        </div>
                        <button id="btn-reset-settings" class="setting-button danger">重置</button>
                    </div>
                </div>
            </div>

            <!-- 底部 -->
            <div class="settings-footer">
                <div class="version-info">版本 v1.0.0</div>
                <div class="settings-actions">
                    <button id="btn-reset" class="setting-button secondary">重置</button>
                    <button id="btn-save-settings" class="setting-button primary">保存</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast 提示 -->
    <div id="toast" class="toast" style="display: none;"></div>

    <!-- 确认对话框 -->
    <div id="confirm-dialog" class="confirm-dialog-overlay" style="display: none;">
        <div class="confirm-dialog">
            <h3 class="confirm-title">确认</h3>
            <p class="confirm-message" id="confirm-message"></p>
            <div class="confirm-actions">
                <button id="btn-confirm-cancel" class="setting-button secondary">取消</button>
                <button id="btn-confirm-ok" class="setting-button primary">确认</button>
            </div>
        </div>
    </div>

    <script src="renderer.js"></script>
    <script src="settings.js"></script>
</body>
</html>

